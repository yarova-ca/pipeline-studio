    "symfony/security-bundle": "^7.2",
    "symfony/uid": "^7.2",
    "doctrine/orm": "^3.0",
    "doctrine/doctrine-bundle": "^2.12",
    "lexik/jwt-authentication-bundle": "^3.0",
