generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  // The BFF compiles to CommonJS (node dist/index.js). Emit a CommonJS client
  // with extensionless relative imports so tsc resolves them under node10.
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  apiKey    String?  @unique @map("api_key")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
