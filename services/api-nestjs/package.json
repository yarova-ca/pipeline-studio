    "@prisma/client": "^6.0.0",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "pino": "^9.5.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "helmet": "^8.0.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/swagger": "^8.1.0",
