    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.7.0",
    "pino-pretty": "^11.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
