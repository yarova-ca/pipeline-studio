generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  apiKey    String?  @unique @map("api_key")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
