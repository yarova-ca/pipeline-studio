---
import Base from '../layouts/Base.astro';
import ConfigBar from '../islands/ConfigBar.svelte';
import PipelineView from '../islands/PipelineView.svelte';
import FileViewer from '../islands/FileViewer.svelte';
import DecisionMap from '../islands/DecisionMap.svelte';
---

<Base title="DevSecOps Pipeline Studio">

  <!-- Config bar — sticky top, full width -->
  <div slot="config-bar" id="config-bar-wrapper">
    <ConfigBar client:load />
  </div>

  <!-- Sidebar — phase nav + invariants reference -->
  <nav slot="sidebar" id="sidebar-nav">
    <div class="nav-section">
      <div class="nav-hdr">Pipeline Phases</div>
      <ul class="nav-list">
        <li><a href="#phase-0" class="nav-item">Phase 0 — Bootstrap</a></li>
        <li><a href="#phase-1" class="nav-item">Phase 1 — Local / Dev</a></li>
        <li><a href="#phase-2" class="nav-item">Phase 2 — PR Gate</a></li>
        <li><a href="#phase-3" class="nav-item">Phase 3 — Main Build</a></li>
        <li><a href="#phase-4" class="nav-item">Phase 4 — Promotions</a></li>
      </ul>
    </div>

    <div class="nav-section">
      <div class="nav-hdr">Decisions</div>
      <ul class="nav-list">
        <li><a href="#decision-map" class="nav-item">Decision Map</a></li>
      </ul>
    </div>

    <div class="nav-section">
      <div class="nav-hdr">Output Files</div>
      <ul class="nav-list">
        <li><a href="#file-viewer" class="nav-item">Generated Files</a></li>
      </ul>
    </div>

    <div class="nav-section">
      <div class="nav-hdr">Security</div>
      <ul class="nav-list">
        <li><a href="#invariants" class="nav-item">20 Invariants</a></li>
        <li><a href="#compliance" class="nav-item">Compliance Map</a></li>
      </ul>
    </div>
  </nav>

  <!-- TOC (right panel) -->
  <div slot="toc" id="toc-content">
    <div class="toc-hdr">On this page</div>
    <ul class="toc-list">
      <li><a href="#pipeline">Pipeline flow</a></li>
      <li><a href="#decision-map">Decision map</a></li>
      <li><a href="#file-viewer">Generated files</a></li>
    </ul>
  </div>

  <!-- ── Main content ──────────────────────────────────────────────────── -->
  <div id="main-content">

    <!-- Hero / intro -->
    <section class="hero" id="pipeline">
      <h1 class="hero-title">DevSecOps Pipeline Studio</h1>
      <p class="hero-sub">
        Select your stack, CI system, and registry above.
        The pipeline, files, and compliance map update instantly.
      </p>
    </section>

    <!-- Interactive pipeline view -->
    <section class="section-block">
      <PipelineView client:load />
    </section>

    <!-- Decision map -->
    <section class="section-block" id="decision-map">
      <DecisionMap client:load />
    </section>

    <!-- Generated files viewer -->
    <section class="section-block" id="file-viewer">
      <div class="section-hdr">
        <h2 class="section-title">Generated Files</h2>
        <p class="section-sub">All files update as you change the config above.</p>
      </div>
      <FileViewer client:load />
    </section>

  </div>
</Base>

<style>
  /* Config bar wrapper */
  #config-bar-wrapper {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky, 50);
    width: 100%;
  }

  /* Sidebar nav */
  #sidebar-nav { padding: 12px 0; }
  .nav-section { margin-bottom: 20px; }
  .nav-hdr {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #768390;
    padding: 0 16px 6px;
  }
  .nav-list { list-style: none; margin: 0; padding: 0; }
  .nav-item {
    display: block;
    padding: 5px 16px;
    font-size: 12px;
    color: #adbac7;
    text-decoration: none;
    border-radius: 0;
    transition: background .1s, color .1s;
  }
  .nav-item:hover { background: rgba(255,255,255,.06); color: #cdd9e5; }

  /* TOC */
  #toc-content { padding: 4px 0; }
  .toc-hdr {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .toc-list { list-style: none; margin: 0; padding: 0; }
  .toc-list a {
    display: block;
    font-size: 11.5px;
    color: var(--muted);
    text-decoration: none;
    padding: 4px 0;
  }
  .toc-list a:hover { color: var(--accent); }

  /* Main content */
  #main-content { min-height: 100vh; }

  /* Hero */
  .hero {
    padding: 28px 28px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .hero-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--text);
  }
  .hero-sub {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* Sections */
  .section-block {
    border-bottom: 1px solid var(--border);
  }
  .section-hdr {
    padding: 20px 24px 12px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .section-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .section-sub {
    font-size: 11.5px;
    color: var(--muted);
  }
</style>
